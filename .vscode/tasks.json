{
  "version": "2.0.0",
  "tasks": [
    // --- YOUR ORIGINAL HARDWARE TASKS ---
    {
      "label": "Delete build Folder",
      "type": "shell",
      "command": "Remove-Item -Recurse -Force ./build",
      "problemMatcher": [],
    },
    {
      "label": "cmake: configure",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        ".",
        "-B",
        "build",
        "-G",
        "Ninja",
        "-DCMAKE_BUILD_TYPE=Debug",
        "-DCMAKE_TOOLCHAIN_FILE=${workspaceFolder}/cmake/arm-none-eabi-toolchain.cmake"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cmake: build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build"
      ],
      "group": "build",
      "dependsOn": [
        "cmake: configure"
      ],
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "cmake: clean",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build",
        "--target",
        "clean"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Flash STM32G431 (CubeProgrammer):",
      "type": "shell",
      "command": "C:\\Program Files\\STMicroelectronics\\STM32Cube\\STM32CubeProgrammer\\bin\\STM32_Programmer_CLI.exe",
      "args": [
        "-c",
        "port=SWD",
        "-w",
        "${workspaceFolder}\\build\\platform\\pmsm_foc_platform.elf",
        "-v",
        "-rst"
      ],
      "problemMatcher": [],
      "dependsOn": [
        "cmake: build"
      ],
      "group": "build"
    },

    {
      "label": "CMake: Configure Host",
      "type": "shell",
      "command": "cmake -S . -B build-host -G Ninja -DPLATFORM=host -DBUILD_TESTS=ON -DCMAKE_BUILD_TYPE=Debug",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Build: Unit Tests",
      "type": "shell",
      "command": "cmake --build build-host --target unit_tests",
      "group": "build",
      "dependsOn": ["CMake: Configure Host"],
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Build: SIL Simulation",
      "type": "shell",
      "command": "cmake --build build-host --target system_test",
      "group": "build",
      "dependsOn": ["CMake: Configure Host"],
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "RUN: Unit Tests",
      "type": "shell",
      "command": "./build-host/tests/unit_tests",
      "group": "test",
      "dependsOn": ["Build: Unit Tests"],
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "RUN: SIL Simulation",
      "type": "shell",
      "command": "${workspaceFolder}/build-host/tests/sim/system_test.exe",
      "args": ["-s"],
      "group": "test",
      "dependsOn": ["Build: SIL Simulation"],
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    }
  ]
}