{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Delete build Folder",
      "type": "shell",
      "command": "Remove-Item -Recurse -Force ./build",
      "problemMatcher": [],
    },
    {
      "label": "cmake: configure",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        ".",
        "-B",
        "build",
        "-G",
        "Ninja",
        "-DCMAKE_BUILD_TYPE=Debug",
        "-DCMAKE_TOOLCHAIN_FILE=${workspaceFolder}/cmake/arm-none-eabi-toolchain.cmake"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cmake: build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build"
      ],
      "group": "build",
      "dependsOn": [
        "cmake: configure"
      ],
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "cmake: clean",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build",
        "--target",
        "clean"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Flash STM32G431 (CubeProgrammer):",
      "type": "shell",
      "command": "C:\\Program Files\\STMicroelectronics\\STM32Cube\\STM32CubeProgrammer\\bin\\STM32_Programmer_CLI.exe",
      "args": [
        "-c",
        "port=SWD",
        "-w",
        "${workspaceFolder}\\build\\platform\\pmsm_foc_platform.elf",
        "-v",
        "-rst"
      ],
      "problemMatcher": [],
      "dependsOn": [
        "cmake: build"
      ],
      "group": "build"
    },
    {
      "label": "tests: configure",
      "type": "shell",
      "command": "cmake -S . -B build-host -G Ninja -DPLATFORM=host -DBUILD_TESTS=ON",
      "problemMatcher": []
    },
    {
      "label": "tests: build (host)",
      "type": "shell",
      "command": "cmake --build build-host",
      "dependsOn": [
        "tests: configure (host)"
      ],
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "tests: run (host)",
      "type": "shell",
      "command": "ctest --test-dir build-host --output-on-failure",
      "dependsOn": [
        "tests: build (host)"
      ],
      "problemMatcher": []
    },
    {
            "label": "CMake: Configure (Host)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", "${workspaceFolder}",
                "-B", "${workspaceFolder}/build-host",
                "-DPLATFORM=host"
            ],
            "problemMatcher": [],
            "group": "build",
            "detail": "Generates the host build files for simulation and unit tests."
        },
        {
            "label": "CMake: Build Simulation Test",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build-host",
                "--target", "system_test",
                "--parallel"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Builds just the system_test executable."
        },
        {
            "label": "Run Simulation Test",
            "type": "process",
            // Note: Depending on your CMake output settings, this might just be "${workspaceFolder}/build-host/system_test"
            "command": "${workspaceFolder}/build-host/tests/sim/system_test.exe",
            "args": [
                // Catch2 arg: show successful tests too (optional, good for debugging)
                "-s" 
            ],
            "dependsOn": "CMake: Build Simulation Test",
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            },
            "detail": "Builds and then executes the Catch2 simulation test."
        }
  ]
}